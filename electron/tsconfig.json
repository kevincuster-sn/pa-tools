{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "../dist-electron",
    "rootDir": "..",
    "sourceMap": true,
    "jsx": "preserve",
    "types": ["node"]
  },
  "include": ["./**/*.ts", "../shared/**/*.ts"],
  "exclude": ["../node_modules", "../dist", "../renderer"]
}
