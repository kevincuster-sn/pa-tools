{
  "name": "pa-tools",
  "version": "0.0.1",
  "private": true,
  "description": "Workbench for ServiceNow Platform Architects",
  "main": "dist-electron/electron/main.js",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "concurrently -k -n next,electron -c blue,magenta \"pnpm dev:next\" \"pnpm dev:electron\"",
    "dev:next": "next dev renderer -p 3000",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron dist-electron/electron/main.js",
    "build": "pnpm build:next && pnpm build:electron && electron-builder",
    "build:next": "next build renderer",
    "build:electron": "tsc -p electron/tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit && tsc -p renderer/tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.18.0",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^9.1.0",
    "fast-xml-parser": "^5.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.2",
    "typescript": "^5.7.3",
    "uuid": "^14.0.0",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.servicenow.pa-tools",
    "productName": "PA Tools",
    "files": [
      "dist-electron/**/*",
      "renderer/out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  }
}
